#include <stdio.h>

int main()
{
    int bt[10], rt[10], n, tq, i;
    int done;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d",&tq);

    do
    {
        done=1;

        for(i=0;i<n;i++)
        {
            if(rt[i]>0)
            {
                done=0;

                if(rt[i]>tq)
                {
                    printf("P%d ",i+1);
                    rt[i]-=tq;
                }
                else
                {
                    printf("P%d ",i+1);
                    rt[i]=0;
                }
            }
        }

    }while(!done);

    return 0;
}
